{
  "name": "linzhonggui",
  "private": true,
  "version": "2.16.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/finalize-service-worker.mjs",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "audit:foundations": "node --experimental-strip-types --no-warnings scripts/audit-foundations.mjs",
    "smoke": "node scripts/smoke.mjs",
    "verify": "npm run build && npm run audit:foundations && npm run smoke"
  },
  "dependencies": {
    "@phosphor-icons/react": "2.1.10",
    "@radix-ui/themes": "3.3.0",
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "gh-pages": "6.3.0",
    "playwright-core": "1.61.1",
    "typescript": "6.0.3",
    "vite": "8.1.0"
  }
}
